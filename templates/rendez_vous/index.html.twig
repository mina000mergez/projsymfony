{% extends 'base.html.twig' %}

{% block title %}Rendez-vous{% endblock %}

{% block body %}
<div style="padding: 40px 30px;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h1 style="
            color: #7c4fa0;
            font-family: 'Comic Sans MS', cursive;
            font-size: 2rem;
            font-weight: 800;
            margin: 0;
        ">
            📅 Liste des Rendez-vous
        </h1>
        <a href="{{ path('app_rendez_vous_new') }}" style="
            background: linear-gradient(135deg, #c084e8, #89a4f5);
            color: white;
            text-decoration: none;
            border-radius: 12px;
            padding: 12px 24px;
            font-weight: 600;
            font-size: 14px;
        ">
            + Nouveau rendez-vous
        </a>
    </div>

    {# Filtre par mois #}
    <div style="background: white; border-radius: 16px; padding: 20px 25px; margin-bottom: 25px; box-shadow: 0 4px 15px rgba(180,160,210,0.15); display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
        <span style="color: #7c4fa0; font-weight: 700; font-size: 15px;">🔍 Filtrer par mois :</span>
        <form method="GET" action="{{ path('app_rendez_vous_index') }}" style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
            <select name="mois" style="
                border: 2px solid #e0d4f5;
                border-radius: 10px;
                padding: 8px 14px;
                color: #6d5b8e;
                font-size: 14px;
                outline: none;
                cursor: pointer;
            ">
                <option value="01" {% if moisActuel == '01' %}selected{% endif %}>Janvier</option>
                <option value="02" {% if moisActuel == '02' %}selected{% endif %}>Février</option>
                <option value="03" {% if moisActuel == '03' %}selected{% endif %}>Mars</option>
                <option value="04" {% if moisActuel == '04' %}selected{% endif %}>Avril</option>
                <option value="05" {% if moisActuel == '05' %}selected{% endif %}>Mai</option>
                <option value="06" {% if moisActuel == '06' %}selected{% endif %}>Juin</option>
                <option value="07" {% if moisActuel == '07' %}selected{% endif %}>Juillet</option>
                <option value="08" {% if moisActuel == '08' %}selected{% endif %}>Août</option>
                <option value="09" {% if moisActuel == '09' %}selected{% endif %}>Septembre</option>
                <option value="10" {% if moisActuel == '10' %}selected{% endif %}>Octobre</option>
                <option value="11" {% if moisActuel == '11' %}selected{% endif %}>Novembre</option>
                <option value="12" {% if moisActuel == '12' %}selected{% endif %}>Décembre</option>
            </select>

            <select name="annee" style="
                border: 2px solid #e0d4f5;
                border-radius: 10px;
                padding: 8px 14px;
                color: #6d5b8e;
                font-size: 14px;
                outline: none;
                cursor: pointer;
            ">
                <option value="2024" {% if anneeActuelle == '2024' %}selected{% endif %}>2024</option>
                <option value="2025" {% if anneeActuelle == '2025' %}selected{% endif %}>2025</option>
                <option value="2026" {% if anneeActuelle == '2026' %}selected{% endif %}>2026</option>
            </select>

            <button type="submit" style="
                background: linear-gradient(135deg, #c084e8, #89a4f5);
                color: white;
                border: none;
                border-radius: 10px;
                padding: 9px 20px;
                font-size: 14px;
                font-weight: 600;
                cursor: pointer;
            ">Filtrer ✨</button>

            <a href="{{ path('app_rendez_vous_index') }}" style="
                color: #b39ddb;
                font-size: 13px;
                text-decoration: none;
                font-weight: 600;
            ">Réinitialiser</a>
        </form>
    </div>

    <div style="background: white; border-radius: 20px; box-shadow: 0 8px 30px rgba(180,160,210,0.2); overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: linear-gradient(135deg, #c084e8, #89a4f5);">
                    <th style="padding: 16px 20px; color: white; font-weight: 600; text-align: left; font-size: 14px;">Id</th>
                    <th style="padding: 16px 20px; color: white; font-weight: 600; text-align: left; font-size: 14px;">Date</th>
                    <th style="padding: 16px 20px; color: white; font-weight: 600; text-align: left; font-size: 14px;">Heure</th>
                    <th style="padding: 16px 20px; color: white; font-weight: 600; text-align: left; font-size: 14px;">Motif</th>
                    <th style="padding: 16px 20px; color: white; font-weight: 600; text-align: left; font-size: 14px;">Statut</th>
                    <th style="padding: 16px 20px; color: white; font-weight: 600; text-align: center; font-size: 14px;">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for rendez_vou in rendez_vous %}
                <tr style="border-bottom: 1px solid #f0e6fa; transition: background 0.2s;"
                    onmouseover="this.style.background='#faf5ff'"
                    onmouseout="this.style.background='white'">
                    <td style="padding: 16px 20px; color: #b39ddb; font-size: 14px;">{{ rendez_vou.id }}</td>
                    <td style="padding: 16px 20px; color: #6d5b8e; font-weight: 600;">{{ rendez_vou.date ? rendez_vou.date|date('Y-m-d') : '' }}</td>
                    <td style="padding: 16px 20px; color: #6d5b8e;">{{ rendez_vou.heure ? rendez_vou.heure|date('H:i:s') : '' }}</td>
                    <td style="padding: 16px 20px; color: #6d5b8e;">{{ rendez_vou.motif }}</td>
                    <td style="padding: 16px 20px;">
                        <span style="background: #f0e6fa; color: #7c4fa0; padding: 4px 12px; border-radius: 20px; font-size: 13px; font-weight: 600;">
                            {{ rendez_vou.status }}
                        </span>
                    </td>
                    <td style="padding: 16px 20px; text-align: center;">
                        <a href="{{ path('app_rendez_vous_show', {'id': rendez_vou.id}) }}" style="</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" style="padding: 40px; text-align: center; color: #b39ddb; font-size: 15px;">
                        🌸 Aucun rendez-vous pour ce mois
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}