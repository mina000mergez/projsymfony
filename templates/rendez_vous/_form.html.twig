{{ form_start(form) }}

<div style="margin-bottom: 20px;">
    <label style="color: #b39ddb; font-weight: 600; font-size: 14px; display: block; margin-bottom: 8px;">Date</label>
    {{ form_widget(form.date, {
        'attr': {
            'style': 'width: 100%; border-radius: 12px; border: 2px solid #e0d4f5; padding: 14px 16px; font-size: 15px; outline: none; box-sizing: border-box; color: #6d5b8e;'
        }
    }) }}
    {{ form_errors(form.date) }}
</div>

<div style="margin-bottom: 20px;">
    <label style="color: #b39ddb; font-weight: 600; font-size: 14px; display: block; margin-bottom: 8px;">Heure</label>
    {{ form_widget(form.heure, {
        'attr': {
            'style': 'width: 100%; border-radius: 12px; border: 2px solid #e0d4f5; padding: 14px 16px; font-size: 15px; outline: none; box-sizing: border-box; color: #6d5b8e;'
        }
    }) }}
    {{ form_errors(form.heure) }}
</div>

<div style="margin-bottom: 20px;">
    <label style="color: #b39ddb; font-weight: 600; font-size: 14px; display: block; margin-bottom: 8px;">Motif</label>
    {{ form_widget(form.motif, {
        'attr': {
            'placeholder': 'Motif du rendez-vous',
            'style': 'width: 100%; border-radius: 12px; border: 2px solid #e0d4f5; padding: 14px 16px; font-size: 15px; outline: none; box-sizing: border-box; color: #6d5b8e;'
        }
    }) }}
    {{ form_errors(form.motif) }}
</div>

<div style="margin-bottom: 20px;">
    <label style="color: #b39ddb; font-weight: 600; font-size: 14px; display: block; margin-bottom: 8px;">Statut</label>
    {{ form_widget(form.status, {
        'attr': {
            'style': 'width: 100%; border-radius: 12px; border: 2px solid #e0d4f5; padding: 14px 16px; font-size: 15px; outline: none; box-sizing: border-box; color: #6d5b8e;'
        }
    }) }}
    {{ form_errors(form.status) }}
</div>

<div style="margin-bottom: 20px;">
    <label style="color: #b39ddb; font-weight: 600; font-size: 14px; display: block; margin-bottom: 8px;">Patient</label>
    {{ form_widget(form.patient, {
        'attr': {
            'style': 'width: 100%; border-radius: 12px; border: 2px solid #e0d4f5; padding: 14px 16px; font-size: 15px; outline: none; box-sizing: border-box; color: #6d5b8e;'
        }
    }) }}
    {{ form_errors(form.patient) }}
</div>

<div style="margin-bottom: 25px;">
    <label style="color: #b39ddb; font-weight: 600; font-size: 14px; display: block; margin-bottom: 8px;">Médecin</label>
    {{ form_widget(form.medecin, {
        'attr': {
            'style': 'width: 100%; border-radius: 12px; border: 2px solid #e0d4f5; padding: 14px 16px; font-size: 15px; outline: none; box-sizing: border-box; color: #6d5b8e;'
        }
    }) }}
    {{ form_errors(form.medecin) }}
</div>

<button type="submit" style="
    width: 100%;
    background: linear-gradient(135deg, #c084e8, #89a4f5);
    color: white;
    border: none;
    border-radius: 12px;
    padding: 14px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
"
onmouseover="this.style.opacity='0.85'"
onmouseout="this.style.opacity='1'">
    {{ button_label|default('Enregistrer') }} ✨
</button>

{{ form_end(form) }}