{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div style="background: white; border-radius: 24px; padding: 50px 40px; width: 100%; max-width: 460px; box-shadow: 0 8px 30px rgba(180,160,210,0.2);">

        {% for message in app.flashes('notice') %}
            <div style="background: #f0e6fa; color: #7c4fa0; border-radius: 12px; padding: 12px 16px; margin-bottom: 20px; font-size: 14px;">
                {{ message }}
            </div>
        {% endfor %}

        <h1 style="
            background: linear-gradient(135deg, #c084e8, #89a4f5);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-family: 'Comic Sans MS', cursive;
            font-size: 2rem;
            text-align: center;
            margin-bottom: 35px;
        ">
            Mot de passe oublié ? 🔑
        </h1>

        <form method="post">

            <label style="
                color: #b39ddb;
                font-weight: 600;
                font-size: 14px;
                letter-spacing: 0.5px;
                display: block;
                margin-bottom: 10px;
            ">
                Adresse email
            </label>

            <input type="email" name="email"
                   placeholder="exemple@email.com"
                   style="
                       width: 100%;
                       border-radius: 12px;
                       border: 2px solid #e0d4f5;
                       padding: 14px 16px;
                       font-size: 15px;
                       outline: none;
                       transition: border-color 0.3s;
                       box-sizing: border-box;
                       color: #6d5b8e;
                       margin-bottom: 25px;
                   "
                   onfocus="this.style.borderColor='#c084e8'"
                   onblur="this.style.borderColor='#e0d4f5'"
                   required autofocus>

            <button type="submit" style="
                width: 100%;
                background: linear-gradient(135deg, #c084e8, #89a4f5);
                color: white;
                border: none;
                border-radius: 12px;
                padding: 14px;
                font-size: 16px;
                font-weight: 600;
                cursor: pointer;
                letter-spacing: 0.5px;
                transition: opacity 0.3s;
            "
            onmouseover="this.style.opacity='0.85'"
            onmouseout="this.style.opacity='1'">
                Valider ✨
            </button>

            <p style="text-align: center; margin-top: 20px; margin-bottom: 0;">
                <a href="{{ path('login') }}" style="color: #b39ddb; font-size: 14px; text-decoration: none;">
                    ← Retour à la connexion
                </a>
            </p>

        </form>
    </div>
</div>
{% endblock %}