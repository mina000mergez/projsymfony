{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe{% endblock %}

{% block body %}
<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div style="background: white; border-radius: 24px; padding: 50px 40px; width: 100%; max-width: 460px; box-shadow: 0 8px 30px rgba(180,160,210,0.2);">

        <h1 style="
            color: #7c4fa0;
            font-family: 'Comic Sans MS', cursive;
            font-size: 2rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 35px;
        ">
            Nouveau mot de passe 🔒
        </h1>

        {% for message in app.flashes('notice') %}
            <div style="background: #f0e6fa; color: #7c4fa0; border-radius: 12px; padding: 12px 16px; margin-bottom: 20px; font-size: 14px;">
                {{ message }}
            </div>
        {% endfor %}

        {{ form_start(form) }}

        <div style="margin-bottom: 20px;">
            <label style="color: #b39ddb; font-weight: 600; font-size: 14px; display: block; margin-bottom: 8px;">
                Nouveau mot de passe
            </label>
            {{ form_widget(form.new_password.first, {
                'attr': {
                    'placeholder': 'Nouveau mot de passe',
                    'style': 'width: 100%; border-radius: 12px; border: 2px solid #e0d4f5; padding: 14px 16px; font-size: 15px; outline: none; box-sizing: border-box; color: #6d5b8e;'
                }
            }) }}
            {{ form_errors(form.new_password.first) }}
        </div>

        <div style="margin-bottom: 25px;">
            <label style="color: #b39ddb; font-weight: 600; font-size: 14px; display: block; margin-bottom: 8px;">
                Confirmer le mot de passe
            </label>
            {{ form_widget(form.new_password.second, {
                'attr': {
                    'placeholder': 'Confirmer le mot de passe',
                    'style': 'width: 100%; border-radius: 12px; border: 2px solid #e0d4f5; padding: 14px 16px; font-size: 15px; outline: none; box-sizing: border-box; color: #6d5b8e;'
                }
            }) }}
            {{ form_errors(form.new_password.second) }}
        </div>

        <button type="submit" style="
            width: 100%;
            background: linear-gradient(135deg, #c084e8, #89a4f5);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            letter-spacing: 0.5px;
            transition: opacity 0.3s;
        "
        onmouseover="this.style.opacity='0.85'"
        onmouseout="this.style.opacity='1'">
            Mettre à jour ✨
        </button>

        {{ form_end(form) }}

    </div>
</div>
{% endblock %}