{% extends 'base.html.twig' %}

{% block title %}Médecin{% endblock %}

{% block body %}
<div style="padding: 40px 30px; max-width: 600px; margin: 0 auto;">

    <h1 style="
        color: #7c4fa0;
        font-family: 'Comic Sans MS', cursive;
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 30px;
        text-align: center;
    ">
        👨‍⚕️ Fiche Médecin
    </h1>

    <div style="background: white; border-radius: 20px; box-shadow: 0 8px 30px rgba(180,160,210,0.2); overflow: hidden; margin-bottom: 25px;">
        <div style="background: linear-gradient(135deg, #c084e8, #89a4f5); padding: 20px 25px;">
            <h2 style="color: white; margin: 0; font-size: 1.3rem; font-weight: 700;">
                Dr. {{ medecin.prenom }} {{ medecin.nom }}
            </h2>
            <span style="background: rgba(255,255,255,0.25); color: white; padding: 4px 12px; border-radius: 20px; font-size: 13px; margin-top: 8px; display: inline-block;">
                {{ medecin.specialite }}
            </span>
        </div>

        <div style="padding: 25px;">
            <div style="display: flex; flex-direction: column; gap: 16px;">

                <div style="display: flex; align-items: center; gap: 15px; padding: 14px 16px; background: #faf5ff; border-radius: 12px;">
                    <span style="color: #b39ddb; font-size: 13px; font-weight: 600; min-width: 100px;">ID</span>
                    <span style="color: #6d5b8e; font-weight: 600;">{{ medecin.id }}</span>
                </div>

                <div style="display: flex; align-items: center; gap: 15px; padding: 14px 16px; background: #faf5ff; border-radius: 12px;">
                    <span style="color: #b39ddb; font-size: 13px; font-weight: 600; min-width: 100px;">Nom</span>
                    <span style="color: #6d5b8e; font-weight: 600;">{{ medecin.nom }}</span>
                </div>

                <div style="display: flex; align-items: center; gap: 15px; padding: 14px 16px; background: #faf5ff; border-radius: 12px;">
                    <span style="color: #b39ddb; font-size: 13px; font-weight: 600; min-width: 100px;">Prénom</span>
                    <span style="color: #6d5b8e;">{{ medecin.prenom }}</span>
                </div>

                <div style="display: flex; align-items: center; gap: 15px; padding: 14px 16px; background: #faf5ff; border-radius: 12px;">
                    <span style="color: #b39ddb; font-size: 13px; font-weight: 600; min-width: 100px;">Spécialité</span>
                    <span style="background: #f0e6fa; color: #7c4fa0; padding: 4px 12px; border-radius: 20px; font-size: 13px; font-weight: 600;">
                        {{ medecin.specialite }}
                    </span>
                </div>

                <div style="display: flex; align-items: center; gap: 15px; padding: 14px 16px; background: #faf5ff; border-radius: 12px;">
                    <span style="color: #b39ddb; font-size: 13px; font-weight: 600; min-width: 100px;">Téléphone</span>
                    <span style="color: #6d5b8e;">📞 {{ medecin.telephone }}</span>
                </div>

            </div>
        </div>
    </div>

    <div style="display: flex; gap: 12px; align-items: center;">
        <a href="{{ path('app_medecin_index') }}" style="
            background: #f0e6fa;
            color: #7c4fa0;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
        ">← Retour à la liste</a>

        <a href="{{ path('app_medecin_edit', {'id': medecin.id}) }}" style="
            background: linear-gradient(135deg, #c084e8, #89a4f5);
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
        ">✏️ Modifier</a>

        {{ include('medecin/_delete_form.html.twig') }}
    </div>

</div>
{% endblock %}