{% extends 'base.html.twig' %}

{% block title %}Médecins{% endblock %}

{% block body %}
<div style="padding: 40px 30px;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h1 style="
            color: #7c4fa0;
            font-family: 'Comic Sans MS', cursive;
            font-size: 2rem;
            font-weight: 800;
            margin: 0;
        ">
            👨‍⚕️ Liste des Médecins
        </h1>
        <a href="{{ path('app_medecin_new') }}" style="
            background: linear-gradient(135deg, #c084e8, #89a4f5);
            color: white;
            text-decoration: none;
            border-radius: 12px;
            padding: 12px 24px;
            font-weight: 600;
            font-size: 14px;
        ">
            + Nouveau médecin
        </a>
    </div>

    <div style="background: white; border-radius: 20px; box-shadow: 0 8px 30px rgba(180,160,210,0.2); overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: linear-gradient(135deg, #c084e8, #89a4f5);">
                    <th style="padding: 16px 20px; color: white; font-weight: 600; text-align: left; font-size: 14px;">ID</th>
                    <th style="padding: 16px 20px; color: white; font-weight: 600; text-align: left; font-size: 14px;">Nom</th>
                    <th style="padding: 16px 20px; color: white; font-weight: 600; text-align: left; font-size: 14px;">Prénom</th>
                    <th style="padding: 16px 20px; color: white; font-weight: 600; text-align: left; font-size: 14px;">Spécialité</th>
                    <th style="padding: 16px 20px; color: white; font-weight: 600; text-align: left; font-size: 14px;">Téléphone</th>
                    <th style="padding: 16px 20px; color: white; font-weight: 600; text-align: center; font-size: 14px;">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for medecin in medecins %}
                <tr style="border-bottom: 1px solid #f0e6fa; transition: background 0.2s;"
                    onmouseover="this.style.background='#faf5ff'"
                    onmouseout="this.style.background='white'">
                    <td style="padding: 16px 20px; color: #b39ddb; font-size: 14px;">{{ medecin.id }}</td>
                    <td style="padding: 16px 20px; color: #6d5b8e; font-weight: 600;">{{ medecin.nom }}</td>
                    <td style="padding: 16px 20px; color: #6d5b8e;">{{ medecin.prenom }}</td>
                    <td style="padding: 16px 20px;">
                        <span style="background: #f0e6fa; color: #7c4fa0; padding: 4px 12px; border-radius: 20px; font-size: 13px; font-weight: 600;">
                            {{ medecin.specialite }}
                        </span>
                    </td>
                    <td style="padding: 16px 20px; color: #6d5b8e;">{{ medecin.telephone }}</td>
                    <td style="padding: 16px 20px; text-align: center;">
                        <a href="{{ path('app_medecin_show', {'id': medecin.id}) }}" style="
                            background: #f0e6fa;
                            color: #7c4fa0;
                            text-decoration: none;
                            padding: 6px 14px;
                            border-radius: 8px;
                            font-size: 13px;
                            font-weight: 600;
                            margin-right: 6px;
                        ">👁 Voir</a>
                        <a href="{{ path('app_medecin_edit', {'id': medecin.id}) }}" style="
                            background: linear-gradient(135deg, #c084e8, #89a4f5);
                            color: white;
                            text-decoration: none;
                            padding: 6px 14px;
                            border-radius: 8px;
                            font-size: 13px;
                            font-weight: 600;
                        ">✏️ Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" style="padding: 40px; text-align: center; color: #b39ddb; font-size: 15px;">
                        🌸 Aucun médecin trouvé
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}