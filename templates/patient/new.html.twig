{% extends 'base.html.twig' %}

{% block title %}Nouveau Patient{% endblock %}

{% block body %}
<div style="padding: 40px 30px; max-width: 550px; margin: 0 auto;">

    <h1 style="
        color: #7c4fa0;
        font-family: 'Comic Sans MS', cursive;
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 30px;
    ">
         Nouveau Patient
    </h1>

    <div style="background: white; border-radius: 20px; padding: 35px; box-shadow: 0 8px 30px rgba(180,160,210,0.2); margin-bottom: 20px;">
        {{ include('patient/_form.html.twig') }}
    </div>

    <a href="{{ path('app_patient_index') }}" style="
        background: #f0e6fa;
        color: #7c4fa0;
        text-decoration: none;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        display: inline-block;
    ">← Retour à la liste</a>

</div>
{% endblock %}