{% extends 'base.html.twig' %}

{% block title %}S'inscrire{% endblock %}

{% block body %}
<div class="d-flex justify-content-center align-items-center" style="min-height: 85vh; padding: 30px 0;">
    <div style="background: white; border-radius: 24px; padding: 50px 40px; width: 100%; max-width: 460px; box-shadow: 0 8px 30px rgba(180,160,210,0.2);">

        <h1 style="
            color: #7c4fa0;
            font-family: 'Comic Sans MS', cursive;
            font-size: 2rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 35px;
        ">
            Créer un compte 
        </h1>

        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}

        <div style="margin-bottom: 20px;">
            <label style="color: #b39ddb; font-weight: 600; font-size: 14px; display: block; margin-bottom: 8px;">
                Nom d'utilisateur
            </label>
            {{ form_widget(registrationForm.username, {
                'attr': {
                    'placeholder': 'Votre nom d\'utilisateur',
                    'style': 'width: 100%; border-radius: 12px; border: 2px solid #e0d4f5; padding: 14px 16px; font-size: 15px; outline: none; box-sizing: border-box; color: #6d5b8e;'
                }
            }) }}
            {{ form_errors(registrationForm.username) }}
        </div>

        <div style="margin-bottom: 20px;">
            <label style="color: #b39ddb; font-weight: 600; font-size: 14px; display: block; margin-bottom: 8px;">
                Adresse email
            </label>
            {{ form_widget(registrationForm.email, {
                'attr': {
                    'placeholder': 'exemple@email.com',
                    'style': 'width: 100%; border-radius: 12px; border: 2px solid #e0d4f5; padding: 14px 16px; font-size: 15px; outline: none; box-sizing: border-box; color: #6d5b8e;'
                }
            }) }}
            {{ form_errors(registrationForm.email) }}
        </div>

        <div style="margin-bottom: 20px;">
            <label style="color: #b39ddb; font-weight: 600; font-size: 14px; display: block; margin-bottom: 8px;">
                Mot de passe
            </label>
            {{ form_widget(registrationForm.plainPassword, {
                'attr': {
                    'placeholder': 'Votre mot de passe',
                    'style': 'width: 100%; border-radius: 12px; border: 2px solid #e0d4f5; padding: 14px 16px; font-size: 15px; outline: none; box-sizing: border-box; color: #6d5b8e;'
                }
            }) }}
            {{ form_errors(registrationForm.plainPassword) }}
        </div>

        <div style="margin-bottom: 25px; display: flex; align-items: center; gap: 10px;">
            {{ form_widget(registrationForm.agreeTerms, {
                'attr': {
                    'style': 'width: 18px; height: 18px; accent-color: #c084e8; cursor: pointer;'
                }
            }) }}
            <label style="color: #b39ddb; font-size: 14px; margin: 0; cursor: pointer;">
                J'accepte les conditions d'utilisation
            </label>
            {{ form_errors(registrationForm.agreeTerms) }}
        </div>

        <button type="submit" style="
            width: 100%;
            background: linear-gradient(135deg, #c084e8, #89a4f5);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            letter-spacing: 0.5px;
            transition: opacity 0.3s;
        "
        onmouseover="this.style.opacity='0.85'"
        onmouseout="this.style.opacity='1'">
            S'inscrire ✨
        </button>

        <p style="text-align: center; margin-top: 20px; margin-bottom: 0;">
            <a href="{{ path('login') }}" style="color: #b39ddb; font-size: 14px; text-decoration: none;">
                Déjà un compte ? Se connecter
            </a>
        </p>

        {{ form_end(registrationForm) }}

    </div>
</div>
{% endblock %}